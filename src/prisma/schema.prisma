generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id         String      @id @default(cuid())
  email      String      @unique
  password   String
  createdAt  DateTime    @default(now())
  onboarding String?
  entries    Entry[]
  edges      GraphEdge[]
  nodes      GraphNode[]
  patterns   Pattern[]
  sessions   Session[]
}

model Entry {
  id        String   @id @default(cuid())
  userId    String
  type      String
  content   String
  pinned    Boolean  @default(false)
  archived  Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tags      Tag[]    @relation("EntryTags")
}

model GraphNode {
  id          String      @id @default(cuid())
  userId      String
  label       String
  type        String
  weight      Float       @default(1.0)
  x           Float?
  y           Float?
  createdAt   DateTime    @default(now())
  targetEdges GraphEdge[] @relation("target")
  sourceEdges GraphEdge[] @relation("source")
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, label])
}

model GraphEdge {
  id        String    @id @default(cuid())
  userId    String
  sourceId  String
  targetId  String
  strength  Float     @default(0.5)
  createdAt DateTime  @default(now())
  target    GraphNode @relation("target", fields: [targetId], references: [id], onDelete: Cascade)
  source    GraphNode @relation("source", fields: [sourceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sourceId, targetId])
}

model Pattern {
  id           String   @id @default(cuid())
  userId       String
  type         String
  title        String
  description  String
  relatedNodes String
  detectedAt   DateTime @default(now())
  seen         Boolean  @default(false)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, title])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Tag {
  id      String  @id @default(cuid())
  name    String  @unique
  entries Entry[] @relation("EntryTags")
}
