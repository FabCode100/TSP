generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String      @id @default(cuid())
  email      String      @unique
  password   String
  photoUrl   String?
  voiceId    String?
  createdAt  DateTime    @default(now())
  onboarding String?
  entries    Entry[]
  edges      GraphEdge[]
  nodes      GraphNode[]
  patterns   Pattern[]
  sessions   Session[]
  twinTokens TwinToken[]
  twinLogs   TwinAccessLog[]
}

model Entry {
  id        String   @id @default(cuid())
  userId    String
  type      String
  content   String
  pinned    Boolean  @default(false)
  archived  Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tags      Tag[]    @relation("EntryTags")
}

model GraphNode {
  id          String      @id @default(cuid())
  userId      String
  label       String
  type        String
  weight      Float       @default(1.0)
  x           Float?
  y           Float?
  createdAt   DateTime    @default(now())
  targetEdges GraphEdge[] @relation("target")
  sourceEdges GraphEdge[] @relation("source")
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, label])
}

model GraphEdge {
  id        String    @id @default(cuid())
  userId    String
  sourceId  String
  targetId  String
  strength  Float     @default(0.5)
  createdAt DateTime  @default(now())
  target    GraphNode @relation("target", fields: [targetId], references: [id], onDelete: Cascade)
  source    GraphNode @relation("source", fields: [sourceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sourceId, targetId])
}

model Pattern {
  id           String   @id @default(cuid())
  userId       String
  type         String
  title        String
  description  String
  relatedNodes String
  detectedAt   DateTime @default(now())
  seen         Boolean  @default(false)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, title])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Tag {
  id      String  @id @default(cuid())
  name    String  @unique
  entries Entry[] @relation("EntryTags")
}

model TwinToken {
  id               String   @id @default(cuid())
  ownerId          String
  token            String   @unique
  permissionLevel  String   // PUBLIC, TRUSTED, INTIMATE
  role             String
  roleInstruction  String
  expiresAt        DateTime?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  
  owner            User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  logs             TwinAccessLog[]
}

model TwinAccessLog {
  id            String   @id @default(cuid())
  tokenId       String
  ownerId       String
  accessorName  String
  duration      Int      // in seconds
  messageCount  Int
  summary       String
  createdAt     DateTime @default(now())

  token         TwinToken @relation(fields: [tokenId], references: [id], onDelete: Cascade)
  owner         User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
}
